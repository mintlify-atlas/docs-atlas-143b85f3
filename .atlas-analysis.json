  "keyFeatures": [
    "Email/password authentication with JWT stored in cookies",
    "Stripe subscription management and billing integration",
    "Multi-tenancy with teams and role-based access control",
    "Team member invitations and management",
    "Activity logging system for user events",
    "Dashboard with CRUD operations",
    "Landing page and pricing page templates",
    "Database migrations with Drizzle ORM",
    "Global and local middleware for route protection",
    "shadcn/ui components with Tailwind CSS"
  ],
  "publicApiSurface": [
    "/api/stripe/checkout",
    "/api/stripe/webhook",
    "/api/team",
    "/api/user",
    "signToken()",
    "verifyToken()",
    "getSession()",
    "setSession()",
    "hashPassword()",
    "comparePasswords()",
    "createCheckoutSession()",
    "createCustomerPortalSession()",
    "handleSubscriptionChange()",
    "getStripePrices()",
    "getStripeProducts()"
  ]
}
